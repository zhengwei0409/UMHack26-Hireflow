{
  "permissions": {
    "allow": [
      "Bash(uv run ruff *)",
      "Bash(uv run pyright *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "mcp__ide__getDiagnostics"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); [[ \"$f\" == *.py ]] && cd \"$CLAUDE_PROJECT_DIR\" && uv run ruff check --fix -q \"$f\" 2>/dev/null && uv run ruff format -q \"$f\" 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
