{
  "$schema": "https://railway.app/railway.schema.json",
  "bot": {
    "build": {
      "dockerfilePath": "docker/Dockerfile.simple",
      "builder": "DOCKER"
    },
    "deploy": {
      "numReplicas": 1,
      "healthCheckPath": "/health"
    }
  },
  "dashboard": {
    "build": {
      "dockerfilePath": "dashboard/Dockerfile",
      "builder": "DOCKER"
    },
    "deploy": {
      "numReplicas": 1
    }
  }
}