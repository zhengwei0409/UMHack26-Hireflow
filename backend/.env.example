# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/umhack_hr"

# Auth
JWT_SECRET="change-this-to-a-random-string"

# Email (SMTP - using Gmail, Outlook, or any SMTP provider)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="hr@yourcompany.com"
COMPANY_NAME="Your Company"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/v1/auth/google/callback"

# GLM API (ILMU AI - ilmu-glm-5.1)
GLM_API_KEY="your-ilmu-ai-key"
GLM_API_BASE="https://api.ilmu.ai/v1"

# App
PORT=3000
NODE_ENV=development

# GitHub API token for reading public repo metadata/package files
# Optional, but recommended to avoid GitHub unauthenticated rate limits.
GITHUB_TOKEN=""
